# Cendorq environment example
# Copy this file to .env.local for local development when needed.
# Do not commit real secrets, private keys, tokens, customer data, webhook secrets, or API keys.

# Canonical public site URL used by SEO metadata, sitemap, robots, structured data, email links, and redirects.
NEXT_PUBLIC_SITE_URL=https://www.cendorq.com

# Public site URL used by smoke checks, production smoke workflow, and deployment verification.
CENDORQ_BASE_URL=https://www.cendorq.com

# Optional comma-separated production origin allowlist for Free Scan intake submissions.
# Defaults to NEXT_PUBLIC_SITE_URL when set. Keep this server-only.
# INTAKE_ALLOWED_ORIGINS=https://www.cendorq.com

# Server-only admin key for protected intake-console reads.
# Set a long random value in production. Do not expose this in client-side code.
INTAKE_CONSOLE_READ_KEY=replace-with-long-random-server-only-key

# Optional server-only alias supported by the API route.
# INTAKE_ADMIN_KEY=replace-with-long-random-server-only-key

# Stripe checkout and webhook runtime.
# Use real values only in Vercel/project secrets, never in Git.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_DEEP_REVIEW=price_replace_deep_review
STRIPE_PRICE_BUILD_FIX=price_replace_build_fix
STRIPE_PRICE_ONGOING_CONTROL=price_replace_ongoing_control

# Public fallback Stripe payment links used only when direct checkout-session creation is not configured.
NEXT_PUBLIC_STRIPE_DEEP_REVIEW_PAYMENT_LINK=https://buy.stripe.com/9B64gAa28eGwdiIbdhcZa05
NEXT_PUBLIC_STRIPE_BUILD_FIX_PAYMENT_LINK=https://buy.stripe.com/dRm5kE0ry2XObaA2GLcZa06
NEXT_PUBLIC_STRIPE_ONGOING_CONTROL_PAYMENT_LINK=https://buy.stripe.com/28EcN65LSaqgdiI1CHcZa07

# Transactional email runtime.
# If RESEND_API_KEY is missing, email access safely reports email-unavailable instead of claiming delivery.
RESEND_API_KEY=re_replace_me
EMAIL_FROM=Cendorq Support <support@cendorq.com>
EMAIL_REPLY_TO=support@cendorq.com
SUPPORT_EMAIL=support@cendorq.com

# Signed remembered customer session.
# Required for "Continue if remembered" after email confirmation.
# Must be at least 32 characters. Generate a random production secret in Vercel.
CENDORQ_CUSTOMER_SESSION_SECRET=replace-with-random-32-plus-character-secret

# Optional provider auth start URLs.
# Leave blank until each provider is actually configured. Buttons fail safely when these are absent.
# These must be HTTPS URLs.
CENDORQ_AUTH_GOOGLE_URL=
CENDORQ_AUTH_MICROSOFT_URL=
CENDORQ_AUTH_APPLE_URL=
CENDORQ_AUTH_LINKEDIN_URL=
CENDORQ_AUTH_FACEBOOK_URL=

# Runtime environment. Next.js sets NODE_ENV automatically in most workflows.
NODE_ENV=development

# Vercel-style environment metadata. These are optional and safely read by /api/health.
VERCEL_ENV=development
VERCEL_GIT_COMMIT_SHA=local

# GitHub-style commit metadata. Optional fallback for /api/health.
GITHUB_SHA=local

# Disable framework telemetry in local scripted checks when desired.
NEXT_TELEMETRY_DISABLED=1
