# Cendorq environment example
# Copy this file to .env.local for local development when needed.
# Do not commit real secrets, private keys, tokens, or customer data.

# Canonical public site URL used by SEO metadata, sitemap, robots, and structured data.
# Production currently uses the www host as canonical; the apex domain redirects to it.
NEXT_PUBLIC_SITE_URL=https://www.cendorq.com

# Apex production URL reference for verification and redirect context.
# NEXT_PUBLIC_SITE_URL=https://cendorq.com is intentionally not the current canonical example.

# Public site URL used by smoke checks, production smoke workflow, and deployment verification.
# Use the canonical www host so strict redirect checks do not stop at the apex-to-www redirect.
CENDORQ_BASE_URL=https://www.cendorq.com

# Apex smoke target reference for verification and redirect context.
# CENDORQ_BASE_URL=https://cendorq.com is intentionally not the current smoke target example.

# Runtime environment. Next.js sets NODE_ENV automatically in most workflows.
NODE_ENV=development

# Vercel-style environment metadata. These are optional and safely read by /api/health.
VERCEL_ENV=development
VERCEL_GIT_COMMIT_SHA=local

# GitHub-style commit metadata. Optional fallback for /api/health.
GITHUB_SHA=local

# Disable framework telemetry in local scripted checks when desired.
NEXT_TELEMETRY_DISABLED=1
