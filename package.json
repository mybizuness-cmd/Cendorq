{
  "name": "cendorq-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "validate:routes": "node ./src/scripts/validate-routes-chain.mjs",
    "validate:public-drift": "node ./src/scripts/validate-public-drift.mjs",
    "validate:free-check-intake": "node ./src/scripts/validate-free-check-intake.mjs",
    "validate:report-truth-engine": "node ./src/scripts/validate-report-truth-engine.mjs",
    "validate:production-smoke-coverage": "node ./src/scripts/validate-production-smoke-coverage.mjs",
    "validate:closed-intelligence": "node ./src/scripts/validate-closed-intelligence.mjs",
    "smoke:production": "node ./src/scripts/smoke-production.mjs",
    "normalize:whitespace": "node ./src/scripts/normalize-whitespace.mjs"
  },
  "dependencies": {
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
