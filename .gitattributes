# Normalize text files consistently across operating systems.
* text=auto eol=lf

# Keep common binary assets out of text diffs.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary

# Keep generated lock and manifest files stable as text.
*.json text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
