{
  "name": "Cendorq — Market Command Intelligence",
  "short_name": "Cendorq",
  "description": "Start the Free Scan, find what the market may be missing, and choose the right command depth before spending more.",
  "start_url": "/free-check?source=app-install",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "background_color": "#020617",
  "theme_color": "#020617",
  "orientation": "portrait-primary",
  "categories": ["business", "productivity"],
  "lang": "en-US",
  "dir": "ltr",
  "icons": [
    {
      "src": "/icon",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/apple-icon",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Free Scan",
      "short_name": "Scan",
      "description": "Start the guided Cendorq market signal scan.",
      "url": "/free-check?source=app-shortcut",
      "icons": [{ "src": "/icon", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Compare Command Path",
      "short_name": "Command Path",
      "description": "Compare Scan, Diagnose, Fix, and Control.",
      "url": "/plans?source=app-shortcut",
      "icons": [{ "src": "/icon", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Open Dashboard",
      "short_name": "Dashboard",
      "description": "Return to protected reports, proof, notifications, and next actions.",
      "url": "/dashboard?source=app-shortcut",
      "icons": [{ "src": "/icon", "sizes": "192x192", "type": "image/png" }]
    }
  ]
}
